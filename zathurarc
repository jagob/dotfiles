# colors
set default-bg      "#fdf6e3" 
set statusbar-bg    "#eee8d5"
set statusbar-fg    "#000000"
set font "Ubuntu Sans Mono 14"

set show-scrollbars true
set page-padding 5
set selection-clipboard clipboard
set scroll-step 40
set zoom-step 10
map <C-+> zoom in
map <C--> zoom out
map <F1> set "pages-per-row 1"
map <F2> set "pages-per-row 2"




