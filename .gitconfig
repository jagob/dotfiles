# comment
; comment

[user]
	name = jagob
	email = jacobvdueholm@hotmail.com

[merge]
	tool = vimdiff
    conflictstyle = diff3

[diff]
	; tool = vimdiff
    external = ~/bin/git_diff_wrapper

[difftool]
	prompt = false

[push]
	default = simple

[pager]
  diff =

[alias]
	lg = log --color --graph --pretty=format:'%C(yellow)%d%Creset %s %Cgreen(%cr)%C(bold blue)<%an>%Creset - %Cred%h%Creset' --name-status
