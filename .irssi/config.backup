# irssi config file
# launch with screen irssi

servers = (
  {
    address = "irc.quakenet.org";
    chatnet = "QuakeNet";
    port = "6667";
    use_ssl = "no";
    ssl_verify = "no";
    autoconnect = "yes";
  },
  {
    address = "irc.freenode.net";
    chatnet = "Freenode";
    port = "6697";
    use_ssl = "yes";
    ssl_verify = "yes";
    ssl_capath = "/etc/ssl/certs";
    autoconnect = "yes";
  },
  {
    address = "vapvet.irc.slack.com";
    chatnet = "slack";
    port = "6667";
    password = "vapvet.AGZDSPerYBC3hLP6OuBi";
    use_ssl = "yes";
    ssl_verify = "no";
    autoconnect = "yes";
  }
);

#THIS SECTION DEALS WITH THE COMMANDS THAT ARE SENT WHEN YOU JOIN A SERVER
