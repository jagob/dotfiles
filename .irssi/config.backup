settings = {
  core = {
    real_name = "Jacob";
    user_name = "jacob";
    nick = "jagob";
    timestamp_format = "%H:%M";
    awaylog_level = "MSGS HILIGHT";
  };
  # "fe-text" = { actlist_sort = "refnum"; };
  "fe-common/core" = {
    theme = "solarized-universal";
    hilight_color = "= %R";
    bell_beeps = "yes";
    # print_active_channel = "yes";
    # use_status_window = "yes";
    # use_msgs_window = "yes";
    #    beep_msg_level = "NOTICE MSGS HILIGHT";
    # activity_hide_level = "= JOINS QUITS";
    # completion_nicks_lowercase = "yes";
    beep_msg_level = "MSGS HILIGHT NOTICES INVITES DCC DCCMSGS";
    autolog = "yes";
  };

  "irc/core" = { alternate_nick = "hamster"; };

  "perl/core/scripts" = {
    awl_block = "-15";
    awl_viewer = "no";
    # neat_allow_shrinking = "no";
    # neat_melength = "3";
    # neat_left_messages = "yes";
    # neat_colorize = "no";
    awl_placement = "top";
    awl_mouse = "yes";
    awl_mouse_offset = "0";
  };
  "fe-text" = { actlist_sort = "refnum"; indent = "26"; };
};

