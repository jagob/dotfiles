# irssi config file
# launch with screen irssi

servers = (
  {
    address = "irc.quakenet.org";
    chatnet = "QuakeNet";
    port = "6667";
    use_ssl = "no";
    ssl_verify = "no";
    autoconnect = "yes";
  },
  {
    address = "irc.freenode.net";
    chatnet = "freenode";
    port = "6667";
    use_ssl = "no";
    ssl_verify = "no";
    autoconnect = "yes";
  }
);


chatnets = {
  QuakeNet = {
    type = "IRC";
    max_kicks = "1";
    max_msgs = "3";
    max_whois = "30";
    # This is how I auth myself at QuakeNet
    # autosendcmd = "/^MSG Q@CServe.quakenet.org auth username password;
  };
  freenode = {
    type = "IRC";
    autosendcmd = "MSG NickServ IDENTIFY password; /MODE nick -i";
  };
  #  {
  #    address = "localhost";
  #    port = "6667";
  #    autoconnect = "Yes";
  #    chatnet = "BitlBee";
