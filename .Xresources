! xrdb -load ~/.Xresources
URxvt*termName: rxvt-unicode-256color

URxvt*loginShell: true
URxvt.depth: 32
URxvt.geometry: 80x32
! URxvt*BellIsUrgent: true
URxvt.urgentOnBell: true
URxvt.saveLines: 1000
URxvt.internalBorder: 3
URxvt.lineSpace: 0
URxvt.iso14755: False 

URxvt*scrollTtyOutput:      false
URxvt*scrollWithBuffer:     true
URxvt*scrollTtyKeypress:    true


URxvt.transparent: false
! URxvt.background: rgba:1111/1111/1111/dddd

! [opacity] #bg color
! URxvt.background: [100]#111111
! URxvt.background: [95]#000000

! ! URxvt*.shading: 0 to 99 darkens, 101 to 200 lightens
! URxvt.shading: 25
! Fade the text by the given percentage when focus is lost; option -fade. 
URxvt.fading: 5


! Xft settings
Xft.dpi: 96
Xft.antialias: true
Xft.rgba: rgb
Xft.hinting: true
! hintfull, hintmedium, hintslight and hintnone
Xft.hintstyle: hintslight
! lcddefault
! lcdlight	: a lighter filter ideal for fonts that look too bold or fuzzy
! lcdlegacy	: the original Cairo filter
! lcdnone	: to disable it entirely
Xft.lcdfilter: lcddefault


XTerm*faceName: Ubuntu Mono
XTerm*faceSize: 14

! Fonts
URxvt.allow_bold: false
URxvt*font: xft:Ubuntu Mono:regular:size=14
URxvt*boldfont: xft:Ubuntu Mono:regular:size=14
! URxvt*font:     xft:Droid Sans Mono :size=12
! URxvt*boldFont: xft:Droid Sans Mono :size=12
! URxvt*font: xft:DejaVu Sans Mono:size=12
! URxvt*font:     xft:Inconsolata:size=14
! URxvt*font:     xft:Terminus:size=14

! Fix font space
!URxvt*letterSpace: -1
 

! Scrollbar
URxvt.scrollBar: false
! scrollbar style - rxvt (default), plain (most compact), next, or xterm
URxvt.scrollStyle: rxvt
URxvt.scrollBar_right: true
URxvt.scrollColor:          #ffffff

! mouse settings
! Xcursor.theme: Neutral++
Xcursor.theme: Human
Xcursor.size:  32

! Cursor
URxvt.cursorBlink: false
URxvt.cursorUnderline: false
! URxvt.cursorColor: #657b83

! Pointer
! True: blank the pointer when a key is pressed or after a set number of seconds of inactivity. False: the pointer is always visible [default]. 
URxvt.pointerBlank: true


! IRC
rxvt*modifier: Windows

!xpdf --------------------------------------
xpdf*enableFreetype:    yes
xpdf*antialias:         yes
xpdf*foreground:        black
xpdf*background:        white
xpdf*urlCommand:        /usr/bin/firefox %s



! Perl extensions --------------------------------------------------------------
! URxvt.perl-ext-common: default,matcher,tabbed,clipboard,confirm-paste,url-select,font,searchable-scrollback,selection-popup,keyboard-select,autocomplete-ALL-the-thin,matchergs, font-size
URxvt.perl-ext-common: default,clipboard,font-size
URxvt.matcher.button: 1
! URxvt.urlLauncher: firefox

!URxvt.clipboard.autocopy 
URxvt.keysym.M-c:	    perl:clipboard:copy
URxvt.keysym.M-v:	    perl:clipboard:paste
! URxvt.keysym.Shift-Control-V: perl:clipboard:paste

URxvt.keysym.C-Up:     perl:font-size:increase
URxvt.keysym.C-Down:   perl:font-size:decrease
! URxvt.keysym.C-S-Up:   perl:font-size:incglobal
! URxvt.keysym.C-S-Down: perl:font-size:decglobal




! URxvt.iconFile: /usr/share/icons/gnome-colors-common/scalable/apps/utilities-terminal.svg
!URxvt.iconFile: /usr/share/icons/gnome-colors-common/16x16/apps/utilities-terminal.png

! ! define colors
! #define S_green         #859900






 
! !Jagob
urxvt*foreground: #e4e4e4
! URxvt*background: [100]#1a1a1a
URxvt*background: [100]#2a2a2a
! black
URxvt*color0  : #2E3436
URxvt*color8  : #abab78
! red
URxvt*color1  : #df0000
URxvt*color9  : #ff0000
! green
URxvt*color2  : #4E9A06
! executable, PS1
URxvt*color10 : #00df5f 
! yellow
URxvt*color3  : #ffaf00
URxvt*color11 : #ff9a00
! blue
!! irssi cmus 
URxvt*color4  : #4a914a 
!! folders
URxvt*color12 : #5faf5f 
! magenta
URxvt*color5  : #75507B
URxvt*color13 : #AD7FA8
! cyan
URxvt*color6  : #00afdf
! symbolic links
URxvt*color14 : #00ff5f
! white
URxvt*color7  : #D3D7CF
URxvt*color15 : #EEEEEC
  



 
