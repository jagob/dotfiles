[general]
ui = TTYUI
# ui = Blinkenlights
# ui = quiet
accounts = aau,jacobgmail
maxsyncaccounts = 2
pythonfile = ~/.mutt/offlineimap.py

[Account jacobgmail]
localrepository = jacobgmail-local
remoterepository = jacobgmail-remote
autorefresh = 2
quick = 10

[Account aau]
localrepository = aau-local
remoterepository = aau-remote
autorefresh = 1
quick = 10

[Repository jacobgmail-local]
type = Maildir
localfolders = ~/.mail/jacobgmail/

[Repository aau-local]
type = Maildir
localfolders = ~/.mail/aau/

[Repository jacobgmail-remote]
type = Gmail
remoteuser = jacobvdueholm@gmail.com
remotepasseval = get_password("mutt_jacobvdueholmATgmailcom")
folderfilter = lambda folder: folder not in['Sent Items',
                                            '[Gmail]/Sendte e-mails'
                                            ]
holdconnectionopen = yes
keepalive = 60
maxconnections = 1
sslcacertfile = /etc/ssl/certs/ca-certificates.crt

[Repository aau-remote]
type = IMAP
remotehost = mail.aau.dk
remoteuser = jdueho11@student.aau.dk
remotepasseval = get_password("mutt_jdueho11")
# nametrans = lambda folder: {
#                            } .get(folder, folder)
folderfilter = lambda folder: folder not in['Calendar',
                                            'Contacts',
                                            'Deleted Items',
                                            'Journal',
                                            'Junk E-Mail',
                                            'Notes',
                                            'Outbox',
                                            'Tasks',
                                            ]
ssl = yes
maxconnections = 1
holdconnectionopen = yes
keepalive = 60
realdelete = no
sslcacertfile = /etc/ssl/certs/ca-certificates.crt


## Just make mailboxes manually
[mbnames]
enabled = no
filename = ~/.mail/jacobgmail/mailboxes
# filename = ~/.mail/aau/mailboxes
header = "mailboxes "
peritem = "+%(accountname)s/%(foldername)s"
sep = " "
footer = "\n"
